# TWLight secret and per-host environment variables.
#
# Copy this file to .env at the repo root and fill in real values:
#   cp template.env .env
#
# .env is gitignored. Variables defined here are loaded by the deployment
# overlay (docker-compose.deploy.yml) into the db, migrate, and twlight
# services. Public per-environment configuration lives in
# conf/<env>.twlight.env and is loaded separately.

# Environment selector. Picks, inside the deployment overlay, the branch_<env>
# image tag and the conf/<env>.{twlight.env,nginx.conf} the stack loads. One of:
# staging, production.
TWLIGHT_ENV=

# Database
DJANGO_DB_NAME=
DJANGO_DB_USER=
DJANGO_DB_PASSWORD=
MYSQL_ROOT_PASSWORD=

# Django
SECRET_KEY=

# OAuth (registered with the MediaWiki OAuth consumer)
TWLIGHT_OAUTH_CONSUMER_KEY=
TWLIGHT_OAUTH_CONSUMER_SECRET=

# EZProxy (shared secret with the OCLC EZProxy server)
TWLIGHT_EZPROXY_SECRET=

# MediaWiki API credentials (bot-password account used for email lookups)
MW_API_EMAIL_USER=
MW_API_EMAIL_PASSWORD=

# DKIM signing key. Multi-line PEM value; quote and preserve newlines:
#   DKIM_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
#   MIIE...
#   -----END RSA PRIVATE KEY-----"
DKIM_PRIVATE_KEY=
